// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid()) @map("_id")
  username  String    @unique
  name      String?
  password  String
  role      String    @default("EMPLOYEE") // "ADMIN", "EMPLOYEE", "PROBATION"
  employee  Employee?
  announcements Announcement[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Employee {
  id               String         @id @default(cuid()) @map("_id")
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  icNo             String?        // Added IC Number
  position         String
  status           String         @default("PERMANENT") // PERMANENT, PROBATION
  joinDate         DateTime       @default(now())
  annualLeaveQuota  Int           @default(14)
  medicalLeaveQuota Int           @default(14)
  unpaidLeaveQuota  Int           @default(10)
  attendanceRecord Attendance[]
  leaveRequests    LeaveRequest[]
  salary           Salary?
  payrolls         Payroll[]
  claims           ExpenseClaim[]
  goalAssignments  GoalAssignment[]
  appraisals       Appraisal[]
  onboardingTasks  OnboardingTask[]
  courses          EmployeeCourse[]
  assets           Asset[]
  benefits         Benefit[]
  surveyResponses  SurveyResponse[]
  profileImage     String?
  bannerImage      String?
  bio              String?
  workingStatus    String           @default("Active")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([joinDate]) // Index for analytics queries (new hires)
  @@index([createdAt]) // Index for recent activity queries
}

model Attendance {
  id         String    @id @default(cuid()) @map("_id")
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime // Midnight date for easier querying
  checkIn    DateTime
  checkOut   DateTime?
  status     String    @default("PRESENT") // "PRESENT", "ABSENT", "LATE"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, date]) // One record per employee per day
  @@index([date, status]) // Index for analytics queries
}

model LeaveRequest {
  id          String   @id @default(cuid()) @map("_id")
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  type        String   @default("ANNUAL") // "ANNUAL", "UNPAID", "MEDICAL"
  reason      String
  status      String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  managerNote String?  // Reason for approval/rejection
  managerSignature String? // Base64 data URL for admin signature
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status]) // Index for analytics queries
  @@index([createdAt]) // Index for recent activity queries
  @@index([employeeId]) // Index for faster employee-specific queries
}

model Salary {
  id          String   @id @default(cuid()) @map("_id")
  employeeId  String   @unique
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseSalary  Float
  allowance   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payroll {
  id          String   @id @default(cuid()) @map("_id")
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month       Int      // 1-12
  year        Int
  basicPay    Float    // Captured at the time of payroll generation
  allowance   Float    @default(0)
  deductions  Float    @default(0)
  netPay      Float    // basicPay + allowance - deductions
  status      String   @default("DRAFT") // DRAFT, PAID
  paymentDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, month, year])
}

model ExpenseClaim {
  id          String   @id @default(cuid()) @map("_id")
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime // Date the expense occurred
  type        String   // e.g., "TRAVEL", "MEDICAL", "MEALS", "SUPPLIES", "OTHER"
  amount      Float
  description String
  receiptUrl  String?  // Optional link to uploaded receipt
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  managerNote String?  // Optional note explaining rejection/approval
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status]) // Index for analytics queries
  @@index([createdAt]) // Index for recent activity queries
}

model JobPosting {
  id          String      @id @default(cuid()) @map("_id")
  title       String
  department  String
  location    String      @default("Remote") // Remote, On-site, Hybrid
  type        String      @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT
  description String
  status      String      @default("OPEN") // OPEN, CLOSED, DRAFT
  applicants  Applicant[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status]) // Index for analytics queries
  @@index([createdAt]) // Index for recent activity queries
}

model Applicant {
  id           String     @id @default(cuid()) @map("_id")
  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  email        String
  phone        String?
  resumeUrl    String?    // Link to uploaded resume
  status       String     @default("APPLIED") // APPLIED, REVIEW, INTERVIEW, OFFERED, REJECTED
  notes        String?    // Interviewer notes
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ==========================================
// Performance Management
// ==========================================

model Goal {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String
  status      String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, AWAITING_APPROVAL, COMPLETED, CANCELLED
  dueDate     DateTime
  rating      String?  // A, B, C, D, F - assigned by admin upon approval
  assignments GoalAssignment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GoalAssignment {
  id          String   @id @default(cuid()) @map("_id")
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status      String   @default("NOT_STARTED") // Tracks completion status per employee
  startedAt   DateTime? // when employee marked started
  completedAt DateTime? // when employee marked done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([goalId, employeeId])
}

model Appraisal {
  id               String   @id @default(cuid()) @map("_id")
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period           String   // e.g., "Q1 2024", "Annual 2024"
  rating           Int?     // 1-5 scale
  comments         String?
  managerId        String?  // Could link to another Employee
  status           String   @default("DRAFT") // DRAFT, SUBMITTED, REVIEWED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==========================================
// Onboarding & Offboarding
// ==========================================

model OnboardingTask {
  id          String   @id @default(cuid()) @map("_id")
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        String   @default("ONBOARDING") // ONBOARDING, OFFBOARDING
  status      String   @default("PENDING") // PENDING, COMPLETED, OVERDUE
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// Training & Development (LMS)
// ==========================================

model Course {
  id          String           @id @default(cuid()) @map("_id")
  title       String
  description String
  provider    String?          // Internal, Coursera, Udemy, etc.
  link        String?          // URL to the course
  mandatory   Boolean          @default(false)
  employees   EmployeeCourse[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model EmployeeCourse {
  id         String    @id @default(cuid()) @map("_id")
  employeeId String
  courseId   String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status     String    @default("ENROLLED") // ENROLLED, IN_PROGRESS, COMPLETED
  enrolledAt DateTime  @default(now())
  completedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, courseId])
}

// ==========================================
// Asset Management
// ==========================================

model Asset {
  id           String    @id @default(cuid()) @map("_id")
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  name         String
  category     String    // e.g., "LAPTOP", "MONITOR", "PHONE", "SOFTWARE"
  serialNumber String?   @unique
  status       String    @default("AVAILABLE") // AVAILABLE, ASSIGNED, MAINTENANCE, RETIRED
  assignedAt   DateTime?
  returnedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ==========================================
// Employee Engagement
// ==========================================

model Announcement {
  id        String   @id @default(cuid()) @map("_id")
  title     String
  content   String
  authorId  String   // User Id of the poster
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  status    String   @default("PUBLISHED") // DRAFT, PUBLISHED, ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid()) @map("_id")
  userId    String?  // User who performed the action (optional for system)
  userName  String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Survey {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      String   @default("OPEN") // DRAFT, OPEN, CLOSED
  dueDate     DateTime?
  questions   SurveyQuestion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SurveyQuestion {
  id          String   @id @default(cuid()) @map("_id")
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questionText String
  type        String   @default("TEXT") // TEXT, CHOICE
  options     String?  // JSON string of options if type is CHOICE
  responses   SurveyResponse[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SurveyResponse {
  id          String   @id @default(cuid()) @map("_id")
  questionId  String
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  answerText  String?  // For TEXT or CHOICE selection
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([questionId, employeeId])
}

// ==========================================
// Benefits Administration
// ==========================================

model Benefit {
  id          String   @id @default(cuid()) @map("_id")
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String   // HEALTH_INSURANCE, GYM, WELLNESS
  provider    String?
  coverage    String?  // INDIVIDUAL, FAMILY
  cost        Float    @default(0)
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
